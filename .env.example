# CAP — Create and Post
# Bắt buộc
APP_URL=http://localhost:3002

# Google Sheet (share Editor cho service account)
CAP_SHEET_ID=1O2rCC-ldE9ySAYFkPN9fz2Y2icuo9FkUIpRjGHaLTUs
CAP_SHEET_TAB=Trang tính1
CAP_SHEET_POLL_MS=30000
CAP_SHEET_CACHE_MS=30000
CAP_MAX_VIDEOS_PER_RUN=5

GOOGLE_APPLICATION_CREDENTIALS=./credentials/google.json
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-bot@your-project.iam.gserviceaccount.com

# Telegram bot CAP (riêng, không dùng chung bot khác)
TELEGRAM_BOT_TOKEN=

# Lịch 8h sáng
DAILY_RUN_HOUR=8
DAILY_RUN_TIMEZONE=Asia/Ho_Chi_Minh
CRON_SECRET=

# Video AI — free | luma | replicate | fal | auto
CAP_VIDEO_PROVIDER=free

# Luma Dream Machine (trả phí) — https://lumalabs.ai/dream-machine/api/keys
# LUMAAI_API_KEY=
# CAP_LUMA_MODEL=ray-flash-2
# CAP_LUMA_RESOLUTION=720p
# CAP_LUMA_DURATION=5s

# Giọng đọc tiếng Việt FREE — Microsoft Edge TTS (không cần API key)
# edge | openai | auto (mặc định auto = Edge trước)
CAP_TTS_PROVIDER=edge
# vi-VN-HoaiMyNeural (nữ) | vi-VN-NamMinhNeural (nam)
CAP_TTS_VOICE=vi-VN-HoaiMyNeural
# CAP_TTS_GENDER=female
# CAP_TTS_RATE=+5%

# Replicate — video chuyển động thật (hết free thì trả phí nhẹ)
# REPLICATE_API_TOKEN=
# CAP_REPLICATE_MODEL=minimax/video-01

# Fal.ai (trả phí) — https://fal.ai/dashboard/keys
# FAL_KEY=

# AI metadata (optional — SEO title/mô tả)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://zenmux.ai/api/v1
OPENAI_MODEL=stepfun/step-3.7-flash-free

# YouTube OAuth — Google Cloud Console → OAuth Web Client
# Redirect: http://localhost:3002/api/auth/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_LOGIN_HINT=your-youtube@gmail.com

# TikTok tắt tạm thời
CAP_ENABLE_TIKTOK=false

# QR login từ điện thoại: mở dashboard bằng IP LAN (không localhost)
# VD: APP_URL=http://192.168.1.4:3002
